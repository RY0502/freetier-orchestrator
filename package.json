{
  "name": "@freetier/orchestrator",
  "version": "0.1.0",
  "description": "Provider-agnostic LangGraph framework that maximizes free-tier usage by juggling multiple providers with retry and rate-limit failover.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "demo": "tsx examples/failover-demo.ts",
    "test": "tsx examples/failover-demo.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@langchain/langgraph": ">=0.2.0"
  },
  "dependencies": {
    "@langchain/langgraph": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
